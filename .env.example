# Example environment file. Copy to `.env` (gitignored) and fill in real values.
#
# The `.env` file is loaded automatically by cartrack_poll.py and the
# audit scripts at module import time, so any KEY=VALUE pair set here
# is available to those tools without needing to `export` in bash.
#
# Already-set process env vars take priority over .env values, so this
# is safe in any context.

# Cartrack Fleet REST API credentials (PH endpoint)
CARTRACK_USERNAME=your_cartrack_api_username
CARTRACK_PASSWORD=your_cartrack_api_password

# Optional: bypass SSL verification on networks with broken cert chains.
# Set to 1 only if you encounter SSL errors and trust the network.
# CARTRACK_INSECURE_SSL=0

# Optional: Google Sheets webhook URL for the /api/sync-to-sheets endpoint
# SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/.../exec
